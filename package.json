{
  "name": "@magam/source",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "app",
    "libs/*"
  ],
  "scripts": {
    "build:core": "cd libs/core && bun run build",
    "build:app": "cd app && bun run build",
    "dev": "bun run scripts/dev/app-dev.ts",
    "ws:dev": "bun run app/ws/server.ts",
    "build": "bun run --filter '@magam/shared' build && bun run --filter '@magam/core' build && bun run --filter '@magam/runtime' build && bun run --filter '@magam/cli' build && bun run build:app",
    "perf:build": "bash scripts/perf/measure-build.sh --label current",
    "perf:dev-routes": "bash scripts/perf/measure-dev-routes.sh --label current",
    "perf:api": "bash scripts/perf/measure-api-latency.sh --label current",
    "perf:report": "bash scripts/perf/report.sh --baseline-label baseline --current-label current",
    "perf:verify:render": "bash scripts/perf/verify-render-consistency.sh",
    "perf:verify:filetree": "bash scripts/perf/verify-filetree-consistency.sh",
    "perf:all": "bun run perf:build && bun run perf:dev-routes && bun run perf:api && bun run perf:report",
    "test": "bun test",
    "test:pdf-golden": "bun test app/utils/pdfGolden.test.ts",
    "test:e2e": "playwright test",
    "chat:smoke": "bun run scripts/chat-smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.8",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "20.19.9",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/react-reconciler": "^0.28.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "autoprefixer": "10.4.13",
    "copy-webpack-plugin": "^13.0.1",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "tailwindcss": "3.4.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@babel/generator": "^7.29.0",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.12",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/websockets": "^11.1.12",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "axios": "^1.6.0",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.5",
    "elkjs": "^0.11.0",
    "esbuild": "^0.27.2",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.563.0",
    "neverthrow": "^8.2.0",
    "pino": "^10.3.0",
    "pino-pretty": "^10.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-reconciler": "^0.29.0",
    "react-syntax-highlighter": "^16.1.0",
    "reactflow": "^11.11.4",
    "reflect-metadata": "^0.1.13",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  }
}

{
  "name": "@magam/source",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "editor",
    "libs/*"
  ],
  "scripts": {
    "build:core": "cd libs/core && bun run build",
    "build:libs": "node scripts/build-libs.mjs",
    "build:editor": "cd editor && bun run build",
    "dev": "cd editor && bun run dev",
    "desktop:build": "node -e \"throw new Error('Desktop integration is deferred during the editor reset.')\"",
    "desktop:dev": "node -e \"throw new Error('Desktop integration is deferred during the editor reset.')\"",
    "web:dev": "cd editor && bun run dev",
    "build": "bun run build:editor",
    "lint:editor": "bunx eslint editor --cache --cache-location .eslintcache",
    "typecheck:editor": "bunx tsc -p editor/tsconfig.json --noEmit",
    "perf:build": "node -e \"throw new Error('Performance scripts are deferred during the editor reset.')\"",
    "perf:dev-routes": "node -e \"throw new Error('Performance scripts are deferred during the editor reset.')\"",
    "perf:api": "node -e \"throw new Error('Performance scripts are deferred during the editor reset.')\"",
    "perf:report": "node -e \"throw new Error('Performance scripts are deferred during the editor reset.')\"",
    "perf:verify:render": "node -e \"throw new Error('Performance scripts are deferred during the editor reset.')\"",
    "perf:verify:filetree": "node -e \"throw new Error('Performance scripts are deferred during the editor reset.')\"",
    "perf:all": "node -e \"throw new Error('Performance scripts are deferred during the editor reset.')\"",
    "test": "bun test",
    "test:pdf-golden": "node -e \"throw new Error('PDF golden tests are deferred during the editor reset.')\"",
    "test:e2e": "node -e \"throw new Error('E2E tests are deferred until the new editor has dedicated coverage.')\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:generate:canonical": "drizzle-kit generate --config=drizzle.canonical.config.ts",
    "db:migrate:canonical": "bun run libs/shared/src/lib/canonical-persistence/pglite-db.ts"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.58.2",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/bun": "^1.3.8",
    "@types/node": "20.19.9",

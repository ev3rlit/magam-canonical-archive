{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://magam.dev/contracts/ai-first-canonical-cli/canvas-hierarchy.v1.schema.json",
  "title": "CanvasHierarchyResponseV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["canvasId", "view", "roots", "orphanNodeIds"],
  "properties": {
    "canvasId": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string"
    },
    "surfaceId": {
      "type": ["string", "null"]
    },
    "view": {
      "enum": ["logical-tree", "render-order"]
    },
    "projection": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "enum": [0, 1] },
            "nodeType": { "const": 1 },
            "nodeKind": { "const": 1 },
            "parentNodeId": { "const": 1 },
            "surfaceId": { "const": 1 },
            "zIndex": { "const": 1 },
            "canonicalObjectId": { "const": 1 },
            "pluginInstanceId": { "const": 1 },
            "layout": { "const": 1 },
            "summary": { "const": 1 },
            "summary.title": { "const": 1 },
            "summary.canonicalTextPreview": { "const": 1 },
            "summary.semanticRole": { "const": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "enum": [0, 1] },
            "nodeType": { "const": 0 },
            "nodeKind": { "const": 0 },
            "parentNodeId": { "const": 0 },
            "surfaceId": { "const": 0 },
            "zIndex": { "const": 0 },
            "canonicalObjectId": { "const": 0 },
            "pluginInstanceId": { "const": 0 },
            "layout": { "const": 0 },
            "summary": { "const": 0 },
            "summary.title": { "const": 0 },
            "summary.canonicalTextPreview": { "const": 0 },
            "summary.semanticRole": { "const": 0 }
          }
        }
      ]
    },
    "roots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hierarchyNode"
      }
    },
    "orphanNodeIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "hierarchySummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": ["string", "null"]
        },
        "canonicalTextPreview": {
          "type": ["string", "null"]
        },
        "semanticRole": {
          "type": ["string", "null"]
        }
      }
    },
    "hierarchyNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nodeType",
        "nodeKind",
        "parentNodeId",
        "surfaceId",
        "zIndex",
        "canonicalObjectId",
        "pluginInstanceId",
        "children"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "nodeType": {
          "type": ["string", "null"]
        },
        "nodeKind": {
          "type": "string",
          "minLength": 1
        },
        "parentNodeId": {
          "type": ["string", "null"]
        },
        "surfaceId": {
          "type": "string",
          "minLength": 1
        },
        "zIndex": {
          "type": "integer"
        },
        "canonicalObjectId": {
          "type": ["string", "null"]
        },
        "pluginInstanceId": {
          "type": ["string", "null"]
        },
        "layout": {
          "type": ["object", "null"]
        },
        "summary": {
          "$ref": "#/$defs/hierarchySummary"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hierarchyNode"
          }
        }
      }
    }
  }
}
